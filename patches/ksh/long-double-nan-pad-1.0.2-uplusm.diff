Description: zero long double padding before the NaN/LDBL_MAX probes
 x86-64's 80-bit long double occupies 16 bytes, six of which are padding that
 nothing initialises. The float feature probes print the byte pattern of a long
 double, so whatever the stack happened to hold leaks into FEATURE/float and the
 build is not reproducible. memset the values before use.
Origin: vendor, shell-versions
Reproducibility: required -- uninitialised padding bytes reach the generated header
Forwarded: not-needed

--- src/lib/libast/features/float
+++ src/lib/libast/features/float
@@ -89,6 +89,7 @@
 	#if _hdr_values
 	#include <values.h>
 	#endif
+	#include <string.h>
 
 	#if !defined(FLT_MIN_EXP) && defined(FMINEXP)
 	#define FLT_MIN_EXP	FMINEXP
@@ -1175,10 +1176,16 @@
 	#endif
 	#ifdef LDBL_MAX
 		{
-			long double	f = LDBL_MAX;
+			long double	f;
 	#if DIV
 			long double	z = 0;
+	#endif
+
+			/* clear padding before assignments to keep byte pattern stable */
+			memset(&f, 0, sizeof(f));
+			f = LDBL_MAX;
+	#if DIV
 
 			f = 0.0 / z;
 			if (!f)
