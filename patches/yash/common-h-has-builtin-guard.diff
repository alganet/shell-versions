Description: split the __has_builtin guard into nested #ifdef/#if
 common.h guards a __builtin_unreachable() call with
   #if defined(__has_builtin) && __has_builtin(__builtin_unreachable)
 but the C preprocessor's #if does not short-circuit at the syntactic level: on
 a compiler where __has_builtin is built in rather than a macro,
 defined(__has_builtin) is false yet the second clause must still parse, and
 __has_builtin(x) is then rejected as a function-like macro that does not exist.
 Nesting the guards keeps the inner clause from being parsed when the outer one
 fails.
Origin: vendor, shell-versions
Forwarded: not-needed

--- common.h	2026-01-01 00:00:00 +0000
+++ common.h	2026-01-01 00:00:00 +0000
@@ -54,15 +54,19 @@
 # define DUMMY_INIT(dummy_initial_value) = (dummy_initial_value)
 #endif

-#if defined(__has_builtin) && __has_builtin(__builtin_unreachable)
-# define UNREACHABLE() \
+#ifdef __has_builtin
+# if __has_builtin(__builtin_unreachable)
+#  define UNREACHABLE() \
     do { \
         assert(!"unreachable code"); \
         __builtin_unreachable(); \
     } while (0)
+# else
+#  define UNREACHABLE() assert(!"unreachable code")
+# endif
 #else
 # define UNREACHABLE() assert(!"unreachable code")
 #endif

 #define ARGV(i) ((wchar_t *) argv[i])

